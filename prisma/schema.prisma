generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Restaurant {
  id          Int     @id @default(autoincrement())
  name        String
  category    String?
  description String?
  imageUrl    String?
  link        String?
}

model Create {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  coverImage  String?
  language    String?
  visibility  String?
  category    String?

  choices     Choice[]
}

model Choice {
  id          Int     @id @default(autoincrement())
  image       String

  createId    Int
  create      Create @relation(fields: [createId], references: [id])
}